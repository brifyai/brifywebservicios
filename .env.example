# Google Drive API Configuration
REACT_APP_GOOGLE_CLIENT_ID=your_google_client_id
REACT_APP_GOOGLE_CLIENT_SECRET=your_google_client_secret
REACT_APP_GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Minimax API Configuration (chat)
REACT_APP_MINIMAX_API_KEY=your_minimax_api_key
REACT_APP_MINIMAX_ENDPOINT=https://api.minimax.io/anthropic/v1/messages
REACT_APP_MINIMAX_MODEL=MiniMax-M2.7
WAHA_MINIMAX_ENABLED=true
WAHA_MINIMAX_TEMPERATURE=0.7
WAHA_ROUTER_ENABLED=true
WAHA_ROUTER_MIN_CONFIDENCE=0.55
WAHA_CASUAL_ENABLED=true
WAHA_CASUAL_MAX_TURNS=12

# Gemini API Configuration (embeddings / memoria)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_EMBEDDINGS_MODEL=embedding-001
GEMINI_VISION_MODEL=gemini-1.5-flash
WAHA_EMBEDDINGS_ENABLED=true
WAHA_EMBEDDINGS_TIMEOUT_MS=15000
WAHA_EMBEDDINGS_MAX_CHUNKS=24
WAHA_VISION_ENABLED=true
WAHA_VISION_TIMEOUT_MS=20000

# Admin (para ejecutar backfill de vectorización)
BRIFY_ADMIN_SECRET=your_admin_secret

# Groq API Configuration (OCR)
REACT_APP_GROQ_API_KEY=your_groq_api_key

# Mercado Pago Configuration
REACT_APP_MERCADO_PAGO_PUBLIC_KEY=your_mercadopago_public_key
REACT_APP_MERCADO_PAGO_ACCESS_TOKEN=your_mercadopago_access_token

# WAHA (WhatsApp HTTP API)
WAHA_BASE_URL=http://localhost:3000
WAHA_API_KEY=your_waha_api_key
WAHA_SESSION=default
WAHA_SEND_ENDPOINT=/api/sendText
WAHA_SEEN_ENDPOINT=/api/sendSeen
WAHA_START_TYPING_ENDPOINT=/api/startTyping
WAHA_STOP_TYPING_ENDPOINT=/api/stopTyping
WAHA_DRIVE_SHARE_ROLE=reader
WAHA_WEBHOOK_SECRET=your_webhook_secret
BRIFY_PROFILE_URL=https://agente.brifyai.com/profile
BRIFY_REGISTER_URL=https://agente.brifyai.com/register

# Supabase Laws Database (RPC buscar_leyes) for WhatsApp legal search
SUPABASE_LAWS_URL=https://your-laws-project.supabase.co
SUPABASE_LAWS_ANON_KEY=your_laws_anon_key
